# RedHydra OpenCore
# Default public mode requires no API key and no login.

REDHYDRA_MODE=opencore-local-no-key

# Optional only:
# To use a self-hosted local model, run Ollama or another OpenAI-compatible
# local server and configure it in the app Settings panel.
#
# Example local endpoint:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Do not commit real API keys to this repository.
