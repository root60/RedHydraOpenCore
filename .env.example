# OpenCore local settings
# Copy this file to .env.local before running locally.

# Required for encrypted provider-key storage in the /v1 gateway.
# Use a long random value.
OPENCORE_GATEWAY_SECRET="replace-with-a-long-random-secret"

# Required when managing gateway provider keys through admin API/UI.
OPENCORE_GATEWAY_ADMIN_KEY="replace-with-an-admin-token"

# Optional: enables OpenAI/ChatGPT models in Gateway Router and OpenAI live TTS voices.
OPENAI_API_KEY=""
OPENCORE_TTS_MODEL="gpt-4o-mini-tts"

# Optional: paste your Hugging Face token in Gateway Router UI, or keep it here for reference.
HF_TOKEN=""
